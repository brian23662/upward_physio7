# Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The "from" address Resend will send contact form emails from.
# This MUST be a domain you've verified in Resend (e.g. hello@upwardphysio.com).
# For local testing you can use the Resend sandbox: onboarding@resend.dev
RESEND_FROM_EMAIL=hello@upwardphysio.com

# Where contact form submissions should be delivered
CONTACT_TO_EMAIL=danieljkeim@gmail.com
